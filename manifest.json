{
  "manifest_version": 3,
  "name": "ZyBook Agent",
  "version": "1.3.0",
  "description": "AI-powered assistant for completing zyBooks assignments using OpenAI",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://learn.zybooks.com/*",
    "https://*.zybooks.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://learn.zybooks.com/*", "https://*.zybooks.com/*"],
      "js": ["content/page-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://learn.zybooks.com/*", "https://*.zybooks.com/*"],
      "js": [
        "content/utils.js",
        "content/scanner.js",
        "content/handlers/animation.js",
        "content/handlers/multiple-choice.js",
        "content/handlers/content-tool.js",
        "content/handlers/short-answer.js",
        "content/handlers/participation.js",
        "content/handlers/coding.js",
        "content/handlers/matching.js",
        "content/handlers/definition-match.js",
        "content/handlers/generic.js",
        "content/handlers/challenge-shared.js",
        "content/handlers/challenge-parsons.js",
        "content/handlers/challenge-coding.js",
        "content/handlers/challenge.js",
        "content/handlers/lab.js",
        "content/main.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/phosphor/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
